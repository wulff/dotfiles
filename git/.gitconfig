; https://jvns.ca/blog/2024/02/16/popular-git-config-options/

[branch]
autosetuprebase = always
sort = -committerdate

[color]
ui = auto

[color "branch"]
current = yellow reverse
local = yellow
remote = green

[color "diff"]
meta = cyan bold
frag = yellow
old = red
new = green

[color "status"]
added = green
changed = red
untracked = cyan

[commit]
gpgSign = true

[core]
whitespace = fix,-indent-with-non-tab,-indent-with-tab,trailing-space,cr-at-eol
editor = vim
excludesfile = ~/.gitignore

[diff]
algorithm = histogram

[fetch]
prune = true

[gpg]
program = /opt/homebrew/bin/gpg

[init]
defaultBranch = main

[log]
date = iso

[merge]
conflictStyle = zdiff3

[pull]
rebase = true

[push]
default = current
followtags = true

[rebase]
autosquash = true
autostash = true

[rerere]
enabled = true

[tag]
gpgSign = true

[user]
name = Morten Wulff
email = wulff@ratatosk.net
signingkey = 8C4ED2E0
